---
import resume from '../data/resume.json';

const { profile } = resume;
---

<section id="hero" class="relative overflow-hidden pb-16 pt-12 sm:pb-20 sm:pt-16">
	<div class="section-shell">
		<div class="grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
			<div class="reveal" data-reveal>
				<p class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-surface/70 px-4 py-1.5 text-sm text-muted">
					<span class="h-2 w-2 rounded-full bg-accent-cyan"></span>
					{profile.location}
				</p>

				<h1 class="font-display text-4xl font-semibold leading-[1.05] tracking-tight text-text sm:text-5xl lg:text-6xl">
					<span class="text-gradient">{profile.name}</span>
				</h1>

				<p class="mt-5 max-w-2xl text-lg font-medium text-text sm:text-xl">
					{profile.title}
				</p>

				<p class="mt-4 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
					{profile.tagline}
				</p>

				<blockquote class="mt-8 max-w-2xl border-l-2 border-accent pl-5 text-base leading-relaxed text-text sm:text-lg">
					"{profile.hook}"
				</blockquote>

				<div class="mt-10 flex flex-wrap gap-3">
					<a
						href="#impact"
						class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-medium text-white transition hover:brightness-110"
					>
						View impact metrics
					</a>
					<a
						href={`mailto:${profile.email}`}
						class="inline-flex items-center justify-center rounded-full border border-border bg-surface/70 px-6 py-3 text-sm font-medium text-text transition hover:border-accent/40"
					>
						Get in touch
					</a>
				</div>
			</div>

			<div class="reveal lg:justify-self-end" data-reveal>
				<div class="relative mx-auto max-w-sm">
					<div
						class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-accent/20 via-transparent to-accent-cyan/20 blur-2xl"
						aria-hidden="true"
					></div>
					<div class="card-surface relative overflow-hidden p-3">
						<img
							src={profile.photo}
							alt={`Portrait of ${profile.name}`}
							width="480"
							height="480"
							loading="eager"
							decoding="async"
							class="aspect-square w-full rounded-[1.25rem] object-cover"
							onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
						/>
						<div
							class="hidden aspect-square w-full items-center justify-center rounded-[1.25rem] bg-gradient-to-br from-accent/30 to-accent-cyan/20"
							aria-hidden="true"
						>
							<span class="font-display text-6xl font-semibold text-text">AS</span>
						</div>
						<div class="mt-4 grid grid-cols-2 gap-3 p-1">
							<div class="rounded-xl bg-elevated/80 px-4 py-3">
								<p class="text-xs uppercase tracking-wide text-muted">Focus</p>
								<p class="mt-1 text-sm font-medium text-text">FinOps & SRE</p>
							</div>
							<div class="rounded-xl bg-elevated/80 px-4 py-3">
								<p class="text-xs uppercase tracking-wide text-muted">Edge</p>
								<p class="mt-1 text-sm font-medium text-text">HEC Paris EMBA</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
