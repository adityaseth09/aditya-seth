---
interface Props {
	value: number;
	prefix?: string;
	suffix?: string;
	label: string;
	index?: number;
}

const { value, prefix = '', suffix = '', label, index = 0 } = Astro.props;
const displayValue = `${prefix}${value}${suffix}`;
---

<article
	class="reveal card-surface group relative overflow-hidden p-6 sm:p-7"
	data-reveal
	style={`transition-delay: ${index * 80}ms`}
>
	<div
		class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"
		aria-hidden="true"
	></div>
	<p
		class="tabular-nums font-display text-4xl font-semibold tracking-tight text-text sm:text-5xl"
		data-count-up
		data-value={value}
		data-prefix={prefix}
		data-suffix={suffix}
	>
		{displayValue}
	</p>
	<p class="mt-3 text-sm font-medium uppercase tracking-[0.16em] text-muted">{label}</p>
</article>
