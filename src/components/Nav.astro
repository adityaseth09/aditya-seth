---
import ThemeToggle from './ThemeToggle.astro';
import resume from '../data/resume.json';

const { profile, navigation } = resume;
---

<header
	class="sticky top-0 z-40 border-b border-border/70 bg-base/80 backdrop-blur-md"
>
	<div class="section-shell flex h-16 items-center justify-between gap-4">
		<a
			href="#hero"
			class="font-display text-sm font-semibold tracking-tight text-text transition hover:text-accent sm:text-base"
		>
			{profile.name.split(' ')[0]}
			<span class="text-muted">{profile.name.split(' ').slice(1).join(' ')}</span>
		</a>

		<nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
			{
				navigation.map((item) => (
					<a
						href={item.href}
						class="rounded-lg px-3 py-2 text-sm text-muted transition hover:bg-elevated/70 hover:text-text"
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-2">
			<a
				href={profile.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="hidden rounded-lg border border-border px-3 py-2 text-sm text-muted transition hover:border-accent/40 hover:text-text sm:inline-flex"
			>
				LinkedIn
			</a>
			<ThemeToggle />
		</div>
	</div>
</header>
