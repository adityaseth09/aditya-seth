---
import Section from './Section.astro';
import resume from '../data/resume.json';
---

<Section
	id="skills"
	eyebrow="Skills Matrix"
	title="Leadership, engineering depth, and infrastructure mastery"
>
	<div class="grid gap-6 lg:grid-cols-3">
		{
			resume.skills.map((group, index) => (
				<article
					class="reveal card-surface p-6 sm:p-7"
					data-reveal
					style={`transition-delay: ${index * 90}ms`}
				>
					<h3 class="font-display text-lg font-semibold text-text">{group.group}</h3>
					<ul class="mt-5 flex flex-wrap gap-2">
						{group.items.map((item) => (
							<li class="rounded-full border border-border bg-elevated/70 px-3 py-1.5 text-sm text-muted">
								{item}
							</li>
						))}
					</ul>
				</article>
			))
		}
	</div>
</Section>
