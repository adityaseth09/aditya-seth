---
import Section from './Section.astro';
import resume from '../data/resume.json';
---

<Section
	id="education"
	eyebrow="Education & Certifications"
	title="Executive education meets deep technical credentials"
>
	<div class="grid gap-6 lg:grid-cols-2">
		<div class="reveal space-y-4" data-reveal>
			<h3 class="font-display text-lg font-semibold text-text">Education</h3>
			{
				resume.education.map((item) => (
					<article class="card-surface p-6">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<div>
								<h4 class="text-lg font-semibold text-text">{item.institution}</h4>
								<p class="mt-1 text-muted">{item.credential}</p>
								{'note' in item && item.note && (
									<p class="mt-2 text-sm text-accent">{item.note}</p>
								)}
							</div>
							{item.start && (
								<p class="text-sm text-muted">
									{item.start}
									{item.end ? ` — ${item.end}` : ''}
								</p>
							)}
						</div>
					</article>
				))
			}
		</div>

		<div class="reveal" data-reveal style="transition-delay: 120ms">
			<h3 class="mb-4 font-display text-lg font-semibold text-text">Certifications</h3>
			<div class="card-surface p-6">
				<ul class="grid gap-3 sm:grid-cols-2">
					{
						resume.certifications.map((cert) => (
							<li class="rounded-xl bg-elevated/60 px-4 py-3 text-sm text-text">
								<a
									href={cert.verifyUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="group flex items-start gap-3 transition hover:text-accent"
								>
									<svg
										class="mt-0.5 h-4 w-4 shrink-0 text-accent"
										viewBox="0 0 20 20"
										fill="currentColor"
										aria-hidden="true"
									>
										<path
											fill-rule="evenodd"
											d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
											clip-rule="evenodd"></path>
									</svg>
									<span>
										{cert.name}
										<span class="mt-0.5 block text-xs text-muted group-hover:text-accent/80">
											Verify credential →
										</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</Section>
